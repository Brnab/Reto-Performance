# ============================================================
# .gitignore — Proyecto: Reto Performance
# ============================================================

# --- Carpetas del proyecto excluidas del repositorio --------
.claude/
.github/
docs/

# --- Dependencias Node.js -----------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# --- Archivos de entorno y secretos -------------------------
.env
.env.local
.env.*.local
*.secret
*.key
secrets/

# --- Logs y salidas temporales ------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.temp

# --- Reportes y resultados de ejecucion k6 ------------------
results/
output/
*.json
!package.json
summary.json

# --- Sistema operativo Windows ------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Sistema operativo macOS --------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# --- IDEs y editores ----------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# --- Archivos compilados y binarios -------------------------
*.class
*.pyc
*.pyo
__pycache__/
*.o
*.a
*.so

# --- Java ---------------------------------------------------
target/
*.jar
*.war
*.ear

# --- Archivos comprimidos -----------------------------------
*.zip
*.tar.gz
*.rar
*.7z

# ============================================================
